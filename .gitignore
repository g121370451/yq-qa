# Python
__pycache__/
*.py[cod]
*$py.class
*.pyd
*.pyo
*.so
.Python
.pytest_cache/
.ruff_cache/
.mypy_cache/
.pyre/
.hypothesis/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
dist/
build/
*.egg-info/

# Node / frontend
node_modules/
apps/*/node_modules/
apps/*/dist/
apps/*/.vite/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Virtual environments
.venv/
venv/
env/
ENV/

# Local environment files
.env
.env.*
!.env.example
!.env.*.example

# IDE / OS
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# Logs and runtime files
logs/
*.log
*.pid
*.tmp
*.temp

# SQLite and local databases
*.sqlite
*.sqlite3
*.sqlite3-shm
*.sqlite3-wal
*.db
*.db-shm
*.db-wal

# App runtime data
apps/*/data/
apps/*/logs/
apps/*/outputs/
apps/rag-openviking-bot/.openviking/
data/uploads/*

# Evaluation datasets and generated artifacts are local/large.
apps/rag-manager-eval/data/
apps/rag-manager-eval/outputs/

# Keep config examples and lockfiles tracked.
!**/.env.example
!**/.env.*.example
!**/configs/*.example
!**/configs/*.yaml.example
!**/uv.lock

# Local OpenViking config files. These usually contain local paths and API keys.
ov.conf
**/ov.conf
*.ov.conf
**/*.ov.conf
!*.ov.conf.example
!**/*.ov.conf.example
