SERVICE_NAME=deepread-rag
DEEPREAD_PROJECT_PATH=D:\project\postgraduate\ruc-ov-eval
DEEPREAD_CORPUS_PATHS=D:\path\to\doc_corpus.json
DEEPREAD_LOG_DIR=logs/deepread

DEEPREAD_MODEL=your-codex-or-openai-compatible-model
DEEPREAD_BASE_URL=https://api.openai.com/v1
DEEPREAD_API_KEY=change-me

DEEPREAD_EMBEDDING_MODEL=your-doubao-embedding-model
DEEPREAD_EMBED_BASE_URL=https://your-doubao-compatible-endpoint/v1
DEEPREAD_EMBED_API_KEY=change-me

# Optional retrieval defaults: bm25, vector, hybrid, semantic
DEEPREAD_RETRIEVAL=hybrid
DEEPREAD_ENABLE_REASONING=true
DEEPREAD_MAX_ROUNDS=50
