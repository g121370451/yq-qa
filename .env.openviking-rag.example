SERVICE_NAME=openviking-rag
OPENVIKING_RAG_PROJECT_PATH=D:\project\mine\OpenViking\benchmark\RAG
OPENVIKING_ROOT_PATH=D:\project\mine\OpenViking
OPENVIKING_RAG_OV_CONF=D:\project\mine\OpenViking\benchmark\RAG\ov.conf

# Existing OpenViking benchmark/RAG vector index directory.
OPENVIKING_RAG_VECTOR_STORE=D:\project\mine\OpenViking\benchmark\RAG\ov_storage\Locomo\Locomo_viking_store_index

# local = use SyncOpenViking directly; http = use an existing openviking-server.
OPENVIKING_RAG_MODE=local
OPENVIKING_RAG_SERVER_URL=http://127.0.0.1:1933
OPENVIKING_RAG_API_KEY=

OPENVIKING_RAG_RETRIEVAL_TOPK=5
OPENVIKING_RAG_RETRIEVAL_INSTRUCTION=
OPENVIKING_RAG_TARGET_URI=viking://resources
OPENVIKING_RAG_USE_RELATIONS=false
OPENVIKING_RAG_RELATIONS_TOPK=0
OPENVIKING_RAG_USE_QUERY_EXPANSION=false
OPENVIKING_RAG_LINK_STRATEGY=llm_review

OPENVIKING_RAG_LLM_MODEL=doubao-seed-2-0-pro-260215
OPENVIKING_RAG_LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
OPENVIKING_RAG_LLM_API_KEY=change-me
OPENVIKING_RAG_LLM_TEMPERATURE=0

OPENVIKING_RAG_EMBEDDING_MODEL=doubao-embedding-vision-251215
OPENVIKING_RAG_EMBEDDING_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
OPENVIKING_RAG_EMBEDDING_API_KEY=change-me
