# Optional startup defaults only.
# The frontend should manage runtime settings through GET/PUT /v1/config,
# and the backend persists them in SQLite.

SERVICE_NAME=yq-qa

YQ_RAG_MANAGER_BASE_URL=http://127.0.0.1:18081
YQ_QA_DB=data/yq-qa.sqlite3
YQ_QA_DEFAULT_METHOD_IDS=openviking-bot-versionrag-chat
YQ_QA_MAX_CONCURRENT_TASKS=4
YQ_QA_METHOD_TIMEOUT_SECONDS=1200

# OpenAI-compatible chat-completions endpoint for merging multiple RAG answers.
YQ_QA_MERGE_ENABLED=false
YQ_QA_MERGE_BASE_URL=https://api.openai.com/v1
YQ_QA_MERGE_API_KEY=replace-me
YQ_QA_MERGE_MODEL=replace-me
YQ_QA_MERGE_TIMEOUT_SECONDS=300
YQ_QA_MERGE_TEMPERATURE=0.2
